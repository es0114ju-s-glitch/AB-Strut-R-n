<%- include('partials/header') %>

<div class="container" style="max-width:540px">
  <div class="card border-0 shadow-sm">
    <div class="card-body p-4 p-md-5">
      <h1 class="fw-bold mb-2" style="font-family:'Fraunces',serif">Logga in</h1>
      <p class="text-muted mb-4">Ange ditt kundnummer för att se dina ordrar direkt.</p>

      <% if (errorMessage) { %>
        <div class="alert alert-danger" role="alert"><%= errorMessage %></div>
      <% } %>

      <form action="/login" method="POST">
        <div class="mb-3">
          <label for="customerNumber" class="form-label fw-semibold">Kundnummer</label>
          <input type="text" id="customerNumber" name="customerNumber" class="form-control form-control-lg" required placeholder="T.ex. K1042">
        </div>
        <button type="submit" class="btn btn-dark btn-lg w-100">Logga in</button>
      </form>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
