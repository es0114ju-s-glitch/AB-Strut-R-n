<%- include('partials/header') %>

<div class="container">
  <h1 class="fw-bold mb-4">Sökresultat för "<%= query %>"</h1>

  <% if (!query || query.trim() === '') { %>
    <div class="alert alert-info">Skriv något i sökfältet högst upp för att hitta produkter.</div>
  <% } else if (results.length === 0) { %>
    <div class="alert alert-warning">Inga produkter matchade din sökning.</div>
  <% } else { %>
    <div class="row row-cols-1 row-cols-md-3 g-4">
      <% results.forEach(function(p) { %>
        <div class="col">
          <div class="card h-100">
            <img src="<%= p.image %>" class="card-img-top" alt="<%= p.name %>">
            <div class="card-body d-flex flex-column">
              <h5 class="card-title"><a href="/products/<%= p.id %>"><%= p.name %></a></h5>
              <p class="card-text text-muted mb-2"><%= p.category %></p>
              <p class="mt-auto"><strong><%= p.price %> kr</strong></p>
            </div>
          </div>
        </div>
      <% }); %>
    </div>
  <% } %>
</div>

<%- include('partials/footer') %>
