<%- include('partials/header') %>

<div class="container">
  <h1 class="fw-bold mb-4" style="font-family:'Fraunces',serif">
    <i class="bi bi-cart3 me-2 text-warning"></i>Kundvagn
  </h1>

  <% if (cart.length === 0) { %>
    <!-- Empty cart state -->
    <div class="text-center py-5">
      <div class="fs-1 mb-3">🛒</div>
      <h4 class="text-muted">Din kundvagn är tom</h4>
      <p class="text-muted">Lägg till produkter från produktkatalogen.</p>
      <a href="/products" class="btn btn-warning btn-lg mt-2">
        <i class="bi bi-grid me-2"></i>Se alla produkter
      </a>
    </div>

  <% } else { %>

    <div class="row g-4">
      <!-- Cart table column -->
      <div class="col-12 col-lg-8">
        <!-- 
          table-responsive = adds horizontal scroll on small screens.
          Without this, wide tables would overflow and break the mobile layout.
        -->
        <div class="table-responsive">
          <table class="table table-hover align-middle">
            <thead class="table-dark">
              <tr>
                <th>Produkt</th>
                <th class="text-center">Antal</th>
                <th class="text-end">À-pris</th>
                <th class="text-end">Summa</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              <!-- 
                EJS loop with index (i) so we can identify which item to remove.
                The index is submitted as a hidden form field to /cart/remove.
              -->
              <% cart.forEach(function(item, i) { %>
                <tr>
                  <td>
                    <strong><%= item.name %></strong>
                    <!-- Show selected size/angle if applicable -->
                    <% if (item.size) { %>
                      <br><small class="text-muted">Storlek: <%= item.size %></small>
                    <% } %>
                    <% if (item.angle) { %>
                      <br><small class="text-muted">Vinkel: <%= item.angle %></small>
                    <% } %>
                  </td>
                  <td class="text-center"><%= item.quantity %></td>
                  <td class="text-end"><%= item.unitPrice.toLocaleString('sv-SE') %> kr</td>
                  <td class="text-end fw-bold"><%= item.subtotal.toLocaleString('sv-SE') %> kr</td>
                  <td>
                    <!-- Remove form: POST to /cart/remove with the cart index -->
                    <form action="/cart/remove" method="POST" class="d-inline">
                      <input type="hidden" name="index" value="<%= i %>">
                      <button type="submit" class="btn btn-sm btn-outline-danger"
                              title="Ta bort">
                        <i class="bi bi-trash"></i>
                      </button>
                    </form>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>

        <a href="/products" class="btn btn-outline-secondary">
          <i class="bi bi-arrow-left me-1"></i>Fortsätt handla
        </a>
      </div>

      <!-- Order summary column -->
      <div class="col-12 col-lg-4">
        <div class="card border-0 shadow-sm">
          <div class="card-body p-4">
            <h5 class="fw-bold mb-4" style="font-family:'Fraunces',serif">Ordersammanfattning</h5>
            <!-- Saved templates (standard orders / inköpslistor) -->
            <form action="/templates/save" method="POST" class="mb-3">
              <div class="input-group">
                <input type="text" name="name" class="form-control" placeholder="Namn på inköpslista (ex. Veckans beställning)">
                <input type="text" name="customerNumber" class="form-control" placeholder="Kundnummer (valfritt)" value="<%= defaultCustomerNumber %>">
                <button class="btn btn-outline-secondary" type="submit">Spara som inköpslista</button>
              </div>
            </form>

            <% if (templates && templates.length > 0) { %>
              <form action="/templates/apply" method="POST" class="mb-3 d-flex">
                <select name="templateId" class="form-select me-2">
                  <% templates.forEach(function(tpl) { %>
                      <option value="<%= tpl.id %>"><%= tpl.name %> — <%= tpl.createdAt.split('T')[0] %></option>
                    <% }); %>
                </select>
                <select name="applyMode" class="form-select me-2">
                  <option value="replace">Ersätt kundvagn</option>
                  <option value="merge">Lägg till ovanpå</option>
                </select>
                <input type="text" name="applyCustomerNumber" class="form-control me-2" placeholder="Kundnummer (valfritt)" value="<%= defaultCustomerNumber %>">
                <!-- We use JS to submit to the correct apply URL when clicking the button -->
                <button id="applyTemplateBtn" type="button" class="btn btn-outline-primary">Använd</button>
              </form>
              <form id="deleteTemplateForm" action="/templates/delete" method="POST">
                <!-- delete form populated by JS when user chooses to delete -->
              </form>
              <script>
                // Small client-side helper: when pressing 'Använd', redirect to
                // the POST route /templates/apply/:id by creating a form and submitting it.
                document.getElementById('applyTemplateBtn').addEventListener('click', function() {
                  const sel = document.querySelector('select[name="templateId"]');
                  if (!sel) return;
                  const id = sel.value;
                  const modeSel = document.querySelector('select[name="applyMode"]');
                  const mode = modeSel ? modeSel.value : 'replace';
                  const cust = document.querySelector('input[name="applyCustomerNumber"]');
                  const custVal = cust ? cust.value : '';

                  const form = document.createElement('form');
                  form.method = 'POST';
                  form.action = '/templates/apply/' + encodeURIComponent(id);

                  const modeInput = document.createElement('input');
                  modeInput.type = 'hidden';
                  modeInput.name = 'mode';
                  modeInput.value = mode;
                  form.appendChild(modeInput);

                  const custInput = document.createElement('input');
                  custInput.type = 'hidden';
                  custInput.name = 'customerNumber';
                  custInput.value = custVal;
                  form.appendChild(custInput);

                  document.body.appendChild(form);
                  form.submit();
                });
              </script>
            <% } %>

            <div class="d-flex justify-content-between mb-2">
              <span class="text-muted">Delsumma (<%= cart.length %> rader)</span>
              <span><%= total.toLocaleString('sv-SE') %> kr</span>
            </div>
            <div class="d-flex justify-content-between mb-2">
              <span class="text-muted">Moms (25%)</span>
              <span><%= Math.round(total * 0.25).toLocaleString('sv-SE') %> kr</span>
            </div>
            <hr>
            <div class="d-flex justify-content-between mb-4">
              <strong>Totalt inkl. moms</strong>
              <strong class="fs-5"><%= Math.round(total * 1.25).toLocaleString('sv-SE') %> kr</strong>
            </div>
            
            <a href="/checkout" class="btn btn-warning btn-lg w-100 fw-semibold">
              <i class="bi bi-credit-card me-2"></i>Till kassan
            </a>

            <div class="mt-3 text-center">
              <small class="text-muted">
                <i class="bi bi-truck me-1"></i>Leverans inom 3 arbetsdagar
              </small>
            </div>
          </div>
        </div>
      </div>
    </div>

  <% } %>
</div>

<%- include('partials/footer') %>
