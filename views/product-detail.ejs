<%- include('partials/header') %>

<div class="container">
  <!-- Breadcrumb navigation -->
  <nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><a href="/" class="text-decoration-none">Hem</a></li>
      <li class="breadcrumb-item"><a href="/products" class="text-decoration-none">Produkter</a></li>
      <li class="breadcrumb-item active"><%= product.name %></li>
    </ol>
  </nav>

  <div class="row g-5">

    <!-- LEFT COLUMN: Product image -->
    <div class="col-12 col-md-5">
      <div class="product-detail-img d-flex align-items-center justify-content-center rounded-3 shadow-sm overflow-hidden">
        <% if (product.image) { %>
          <img src="<%= product.image %>" alt="<%= product.name %>" class="w-100 h-100" style="object-fit:cover;">
        <% } else { %>
          <% if (product.category === 'Strutar') { %>
            <span style="font-size:8rem">🍦</span>
          <% } else if (product.category === 'Rån') { %>
            <span style="font-size:8rem">🥐</span>
          <% } else if (product.category === 'Bägare') { %>
            <span style="font-size:8rem">🥤</span>
          <% } else { %>
            <span style="font-size:8rem">⚙️</span>
          <% } %>
        <% } %>
      </div>

      <!-- Special note for Rån (e.g. Karnevalsrånet) -->
      <% if (product.note) { %>
        <div class="alert alert-warning mt-3">
          <i class="bi bi-star-fill me-2"></i><%= product.note %>
        </div>
      <% } %>
    </div>

    <!-- RIGHT COLUMN: Product info + order form -->
    <div class="col-12 col-md-7">
      
      <span class="badge bg-dark mb-2"><%= product.category %></span>
      <h1 class="fw-bold mb-2" style="font-family:'Fraunces',serif"><%= product.name %></h1>
      
      <!-- Price -->
      <p class="fs-2 fw-bold text-dark mb-1">
        <span id="product-price-value"><%= product.price.toLocaleString('sv-SE') %></span> kr
        <small class="fs-6 text-muted fw-normal">exkl. moms / förpackning</small>
      </p>

      <!-- Stock badge -->
      <div class="mb-4" id="stock-badge-wrap">
        <% if (product.category === 'Strutar' && product.stockPerSize) { %>
          <span class="badge bg-secondary fs-6" id="size-stock-badge">
            <i class="bi bi-rulers me-1"></i>Välj storlek för att se lagersaldo
          </span>
        <% } else if (product.stock === 0) { %>
          <span class="badge bg-danger fs-6">
            <i class="bi bi-x-circle me-1"></i>Slut i lager
          </span>
        <% } else if (product.stock < 20) { %>
          <span class="badge bg-warning text-dark fs-6">
            <i class="bi bi-exclamation-circle me-1"></i>Få kvar — <%= product.stock %> förpackningar
          </span>
        <% } else { %>
          <span class="badge bg-success fs-6">
            <i class="bi bi-check-circle me-1"></i>I lager — <%= product.stock %> förpackningar
          </span>
        <% } %>
      </div>

      <p class="text-muted mb-4"><%= product.description %></p>

      <!-- ====================================================================
           ORDER FORM
           This form POSTs to /cart/add with product details.
           The form only shows size/angle options for relevant categories.
           ==================================================================== -->
      <% if (product.category === 'Glassmaskiner') { %>
        <div class="bg-light rounded-3 p-4 border">
          <h5 class="fw-bold mb-2">Begär offert</h5>
          <p class="text-muted mb-3">Maskiner kräver behovsanalys, installation och planering innan köp.</p>
          <a href="/offert?productId=<%= product.id %>" class="btn btn-primary btn-lg fw-semibold">
            <i class="bi bi-file-earmark-text me-2"></i>Begär offert
          </a>
        </div>
      <% } else if (product.stock > 0) { %>
        <form action="/cart/add" method="POST" class="bg-light rounded-3 p-4 border">
          <!-- Hidden field: tells the controller WHICH product is being added -->
          <input type="hidden" name="productId" value="<%= product.id %>">

          <!-- ==================================================================
               STRUT SIZE SELECTOR
               WHY 16 SIZES?
               Soft-serve ice cream machines have different cone exit diameters.
               A cone that's too small falls through; too big won't fit the holder.
               Professional kiosk owners know their machine's diameter and must
               order the matching cone size. 45mm (smallest) to 120mm (largest)
               covers all commercial machines used in Sweden.
               ================================================================== -->
          <% if (product.category === 'Strutar' && product.availableSizes) { %>
            <div class="mb-3">
              <label for="size" class="form-label fw-semibold">
                Välj storlek (strutens diameter)
              </label>
              <select class="form-select" name="size" id="size" required>
                <option value="">-- Välj storlek --</option>
                <% product.availableSizes.forEach(function(sizeOption) { %>
                  <option
                    value="<%= sizeOption %>"
                    data-stock="<%= product.stockPerSize && product.stockPerSize[sizeOption] != null ? product.stockPerSize[sizeOption] : 0 %>"
                    data-price="<%= product.pricePerSize && product.pricePerSize[sizeOption] != null ? product.pricePerSize[sizeOption] : product.price %>"
                  >
                    <%= sizeOption %>
                  </option>
                <% }); %>
              </select>
              <div class="form-text">
                <i class="bi bi-info-circle me-1 text-info-dark"></i>
                Osäker på storleken? Kolla i din maskins manual eller ring oss på 040-12 34 56.
              </div>
            </div>
          <% } %>

          <!-- ==================================================================
               RÅN SIZE + ANGLE SELECTOR
               Rånar (wafer rolls) vary by two dimensions:
               - Size: how many ice cream scoops they hold
               - Angle: how wide the cone opening is (affects ice cream presentation)
               ================================================================== -->
          <% if (product.category === 'Rån' && product.sizes) { %>
            <div class="mb-3">
              <label for="size" class="form-label fw-semibold">Välj storlek</label>
              <select class="form-select" name="size" id="size" required>
                <option value="">-- Välj storlek --</option>
                <% product.sizes.forEach(function(s) { %>
                  <option value="<%= s %>"><%= s %></option>
                <% }); %>
              </select>
            </div>
            <div class="mb-3">
              <label for="angle" class="form-label fw-semibold">Välj vinkel</label>
              <select class="form-select" name="angle" id="angle" required>
                <option value="">-- Välj vinkel --</option>
                <% product.angles.forEach(function(a) { %>
                  <option value="<%= a %>"><%= a %></option>
                <% }); %>
              </select>
              <div class="form-text">
                Smal = traditionell glasskiosk-look. Bred = mer öppen, passar rånar med toppings.
              </div>
            </div>
          <% } %>

          <!-- Quantity -->
          <div class="mb-4">
            <label for="quantity" class="form-label fw-semibold">Antal förpackningar</label>
            <input type="number" class="form-control" name="quantity" id="quantity"
                   value="1" min="1" max="999" style="max-width:120px">
          </div>

          <!-- Submit button — btn-lg for easier tapping on phones -->
          <button type="submit" class="btn btn-warning btn-lg fw-semibold me-2" id="add-to-cart-btn">
            <i class="bi bi-cart-plus me-2"></i>Lägg i kundvagn
          </button>
          <a href="/products" class="btn btn-outline-secondary btn-lg">
            <i class="bi bi-arrow-left me-1"></i>Tillbaka
          </a>
        </form>

      <% } else { %>
        <!-- Out of stock — show a contact prompt instead of the order form -->
        <div class="alert alert-danger">
          <h5><i class="bi bi-x-circle me-2"></i>Slut i lager</h5>
          <p class="mb-0">Kontakta oss för att beställa eller bli notifierad när produkten är tillbaka.</p>
          <a href="tel:040123456" class="btn btn-danger mt-3">
            <i class="bi bi-telephone me-2"></i>Ring oss: 040-12 34 56
          </a>
        </div>
      <% } %>

    </div>
  </div>
</div>

<% if (addedToCart) { %>
  <div class="position-fixed bottom-0 end-0 p-3" style="z-index: 1080">
    <div id="addedToast" class="toast align-items-center text-bg-success border-0" role="alert" aria-live="assertive" aria-atomic="true">
      <div class="d-flex">
        <div class="toast-body">Produkten har lagts till i kundvagnen ✓</div>
        <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
      </div>
    </div>
  </div>
<% } %>

<script>
  const sizeSelect = document.getElementById('size');
  const productPriceValue = document.getElementById('product-price-value');
  const sizeStockBadge = document.getElementById('size-stock-badge');
  const addToCartBtn = document.getElementById('add-to-cart-btn');

  if (sizeSelect && sizeStockBadge) {
    function updateStockBadge() {
      const selectedOption = sizeSelect.options[sizeSelect.selectedIndex];
      const stockValue = Number(selectedOption ? selectedOption.getAttribute('data-stock') : NaN);

      if (!selectedOption || !selectedOption.value) {
        sizeStockBadge.className = 'badge bg-secondary fs-6';
        sizeStockBadge.innerHTML = '<i class="bi bi-rulers me-1"></i>Välj storlek för att se lagersaldo';
        if (productPriceValue) {
          productPriceValue.textContent = '<%= product.price.toLocaleString('sv-SE') %>';
        }
        if (addToCartBtn) addToCartBtn.disabled = true;
        return;
      }

      const sizePrice = Number(selectedOption.getAttribute('data-price'));
      if (productPriceValue && Number.isFinite(sizePrice)) {
        productPriceValue.textContent = sizePrice.toLocaleString('sv-SE');
      }

      if (!Number.isFinite(stockValue) || stockValue <= 0) {
        sizeStockBadge.className = 'badge bg-danger fs-6';
        sizeStockBadge.innerHTML = '<i class="bi bi-x-circle me-1"></i>Slut i lager - ' + selectedOption.value;
        if (addToCartBtn) addToCartBtn.disabled = true;
      } else if (stockValue < 20) {
        sizeStockBadge.className = 'badge bg-warning text-dark fs-6';
        sizeStockBadge.innerHTML = '<i class="bi bi-exclamation-circle me-1"></i>Få kvar - ' + selectedOption.value + ' (' + stockValue + ' st)';
        if (addToCartBtn) addToCartBtn.disabled = false;
      } else {
        sizeStockBadge.className = 'badge bg-success fs-6';
        sizeStockBadge.innerHTML = '<i class="bi bi-check-circle me-1"></i>I lager - ' + selectedOption.value + ' (' + stockValue + ' st)';
        if (addToCartBtn) addToCartBtn.disabled = false;
      }
    }

    sizeSelect.addEventListener('change', updateStockBadge);
    updateStockBadge();
  }

  window.addEventListener('load', function() {
    const addedToast = document.getElementById('addedToast');
    if (addedToast && window.bootstrap) {
      const toast = new bootstrap.Toast(addedToast, { delay: 2600 });
      toast.show();
    }
  });
</script>

<%- include('partials/footer') %>
